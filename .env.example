# ─────────────────────────────────────────────────────────────
# Database
# Локально: один Postgres (Docker) — DATABASE_URL достатньо.
# Neon (прод): DATABASE_URL = pooled (…-pooler.…, ?sslmode=require&pgbouncer=true),
#              DIRECT_URL   = direct (без -pooler) — потрібен для prisma migrate.
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cryptoportfolio"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/cryptoportfolio"

# ─────────────────────────────────────────────────────────────
# NextAuth.js (Auth.js v5)
# На Vercel: NEXTAUTH_URL/NEXT_PUBLIC_APP_URL = https://<your-app>.vercel.app
# Секрет: згенеруй `openssl rand -base64 32` (мін. 32 символи).
# ─────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-min-32-chars-change-me-please"
AUTH_SECRET="your-secret-key-min-32-chars-change-me-please"
AUTH_TRUST_HOST="true"

# ─────────────────────────────────────────────────────────────
# Moralis (https://admin.moralis.io) — баланси/токени EVM + Solana
# ─────────────────────────────────────────────────────────────
MORALIS_API_KEY="your-moralis-api-key"

# ─────────────────────────────────────────────────────────────
# Ankr (https://www.ankr.com/rpc/) — EVM-транзакції (Advanced API)
# ─────────────────────────────────────────────────────────────
ANKR_API_KEY="your-ankr-api-key"

# ─────────────────────────────────────────────────────────────
# Helius (https://www.helius.dev) + Solana RPC — Solana-транзакції
# ─────────────────────────────────────────────────────────────
HELIUS_API_KEY="your-helius-api-key"
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"

# ─────────────────────────────────────────────────────────────
# CoinGecko (https://www.coingecko.com/en/api) — ціни/ринок
# ─────────────────────────────────────────────────────────────
COINGECKO_API_KEY=""
COINGECKO_BASE_URL="https://api.coingecko.com/api/v3"

# ─────────────────────────────────────────────────────────────
# Telegram Bot (https://t.me/BotFather) — сповіщення про тригери
# TELEGRAM_WEBHOOK_SECRET — будь-який рядок; перевіряється у /api/telegram/webhook
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_WEBHOOK_SECRET="random-webhook-secret"

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# Seed (`prisma db seed`) — демо-значення, змініть для реального деплою
# ─────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin12345"
SEED_PASSWORD="user12345"

# ─────────────────────────────────────────────────────────────
# Cron
# CRON_SECRET    — захист /api/cron/update-prices (Vercel слати Bearer-ом).
# CRON_SCHEDULE  — лише для локального node-cron (npm run cron:local).
# ─────────────────────────────────────────────────────────────
CRON_SECRET="random-cron-secret"
CRON_SCHEDULE="* * * * *"
